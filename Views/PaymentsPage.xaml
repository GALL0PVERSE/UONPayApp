<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UONPayApp.Views.PaymentsPage"
             Title="Make a Payment">
    <ScrollView>
        <VerticalStackLayout Padding="16">
            <Frame Style="{StaticResource CardFrameStyle}" BackgroundColor="{StaticResource Primary}" Padding="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Complete Payment" FontSize="24" TextColor="White" FontAttributes="Bold" />
                    <Label x:Name="AccountPaymentInfoLabel" Text="Cards for this student account" TextColor="#DDECF7" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Saved Cards For This Account" Style="{StaticResource SectionTitleStyle}" />
                    <CollectionView x:Name="SavedCardsView" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No saved cards for this student account." TextColor="{StaticResource TextMuted}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" CornerRadius="14" Padding="14" BorderColor="#D9E2EC" HasShadow="False">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <Label Text="{Binding Brand}" FontAttributes="Bold" FontSize="16" />
                                        <Label Grid.Column="1" Text="•••• {Binding Last4Digits}" FontAttributes="Bold" />
                                        <Label Grid.Row="1" Text="{Binding CardholderName}" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="Exp {Binding Expiry}" TextColor="{StaticResource TextMuted}" HorizontalTextAlignment="End" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Payment Details" Style="{StaticResource SectionTitleStyle}" />
                    <Picker x:Name="PaymentTypePicker" Title="Select fee type" SelectedIndex="0" />
                    <Entry x:Name="AmountEntry" Placeholder="Amount" Keyboard="Numeric" />
                    <Entry x:Name="ReferenceEntry" Placeholder="Reference / note" />
                    <Picker x:Name="PaymentMethodPicker" Title="Select payment method" />
                    <Button Text="Submit Payment" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnPayNowClicked" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Outstanding Balance" Style="{StaticResource SectionTitleStyle}" />
                    <Label x:Name="BalanceLabel" Text="$0.00" FontSize="28" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
