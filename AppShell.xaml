<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="UONPayApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:UONPayApp.Views"
    Shell.TabBarForegroundColor="#6B7280"
    Shell.TabBarTitleColor="#0B6AAE"
    Shell.TabBarUnselectedColor="#9CA3AF"
    Shell.TabBarBackgroundColor="White">

    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate views:HomePage}" Route="home" />
        <ShellContent Title="Payments" ContentTemplate="{DataTemplate views:PaymentsPage}" Route="payments" />
        <ShellContent Title="History" ContentTemplate="{DataTemplate views:HistoryPage}" Route="history" />
        <ShellContent Title="Profile" ContentTemplate="{DataTemplate views:ProfilePage}" Route="profile" />
    </TabBar>
</Shell>
